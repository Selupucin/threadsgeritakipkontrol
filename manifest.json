{
  "manifest_version": 3,
  "name": "TGTK — Threads Geri Takip Kontrol",
  "version": "1.0.1",
  "description": "Threads'te seni geri takip etmeyenleri bul. Sadece-okuma; verilerin cihazından çıkmaz, sunucu yok.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "TGTK — Geri Takip Kontrol",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.threads.com/*",
    "https://www.threads.net/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.threads.com/*", "https://www.threads.net/*"],
      "js": ["src/lib/lottie.min.js", "src/anim/cat.anim.js", "src/content/content.js"],
      "run_at": "document_idle"
    }
  ]
}
